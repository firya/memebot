# Bot token from @BotFather
TELEGRAM_TOKEN=

# Gemini API key
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cloudflare Worker URL for Gemini (use when Gemini is geo-blocked, see gemini-worker/worker.js)
#GEMINI_WORKER_URL=https://gemini-worker.yourname.workers.dev
#GEMINI_WORKER_SECRET=

# Public channel to index (with @)
CHANNEL_USERNAME=@mychannel

# Numeric ID of the private chat the bot uses as a temporary dump
# (bot must be admin there). Get it by forwarding a message to @userinfobot.
DUMP_CHAT_ID=-100123456789

# Your Telegram user ID — receives error alerts
ADMIN_ID=123456789

# Environment: "dev" resets DB on start, indexes only 10 photos, sends AI results to admin
# Leave empty or set to "prod" for normal operation
APP_ENV=prod

# Optional: override DB path (default: /app/data/memes.db)
# DB_PATH=/app/data/memes.db

# Number of consecutive missing messages before crawler considers history exhausted (default: 100)
# Increase if your channel has large gaps in message IDs
# CRAWLER_MAX_GAP=100
